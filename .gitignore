# === Python ===
.venv/
.venv-dbt/
__pycache__/
*.py[cod]
*$py.class
*.env

# === Tooling caches & test/coverage artifacts ===
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# === Spark / Derby scratch (test runs) ===
spark-warehouse/
metastore_db/
derby.log

# === Project Specific Data (checkpoints, logs, data) ===
# We ignore the actual data files, checkpoints, and logs, but keep the directory structure and .gitkeep files for checkpoints and logs.
data/checkpoints/*
data/logs/*

# Keep the directory structure and .gitkeep files for checkpoints and logs
!data/checkpoints/.gitkeep
!data/logs/.gitkeep

# === Image archive (kept locally, never committed) ===
# Old loose screenshots + the full raw recording set live under images/archive/.
# Only the curated, renamed screenshots in images/ (root) are committed to the README.
images/archive/

# === Promo / video production (kept locally, never committed) ===
# Raw Screen Studio recordings (multi-GB), shot lists, and the production guide are
# personal working files for the demo video — not part of the shipped project.
promo/

# === OS specifics ===
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
# === Pre-publish security baseline (added 2026-06-22) ===
PRE-PUBLISH.md
*.pem
*.key
*.p12
*.pfx
