# ==============================================================================
# 📡 IoT Data Pipeline - Environment Configuration Example
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to create a local .env file: cp .env.example .env
# 2. Modify the values below according to your setup.
# 3. DO NOT commit the actual .env file to version control (Git).
# ==============================================================================

# === 📨 KAFKA SETTINGS ===
# Default is 'kafka:9092' for running scripts INSIDE Docker.
# Change to 'localhost:29092' ONLY if running scripts on your local host machine.
KAFKA_BROKER=kafka-broker:9092
KAFKA_TOPIC=sensor_data
# Number of partitions for the topic (Spark consumes partitions in parallel).
KAFKA_PARTITIONS=3
# Wire format for sensor messages: 'avro' (Confluent Schema Registry, schema-governed)
# or 'json' (plain JSON, no registry needed). The simulator and Spark must agree.
SERIALIZATION_FORMAT=avro
# Confluent Schema Registry URL (used only when SERIALIZATION_FORMAT=avro).
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# === 🌡️ SIMULATOR SETTINGS ===
SENSOR_COUNT=5
DELAY_SECONDS=1.0
MAX_RETRIES=10
RETRY_DELAY=3

# === 🧠 REDIS SETTINGS ===
# Default is 'redis' for running scripts INSIDE Docker.
# Change to 'localhost' ONLY if running scripts on your local host machine.
REDIS_HOST=redis
REDIS_PORT=6379
# Redis password — applied to the broker, the Spark sink, and the Grafana
# datasource. Change this for any non-local deployment.
REDIS_PASSWORD=iot-streaming-demo

# === 📊 GRAFANA SETTINGS ===
# Admin login password for the Grafana UI (user: admin).
GRAFANA_ADMIN_PASSWORD=admin
# Webhook receiver for the provisioned drift alert (fires when a metric's drift
# z-score breaches 3 sigma). Point it at Slack/Alertmanager/any webhook sink.
# Leave the default to boot without a real receiver (alerts just won't deliver).
DRIFT_ALERT_WEBHOOK_URL=http://host.docker.internal:5001/drift

# === ⚙️ SPARK STREAMING SETTINGS ===
# Checkpoint directory for Spark Fault Tolerance.
# Stored inside the /data volume which is ignored by Git.
CHECKPOINT_DIR=./data/checkpoints/sensor_data

# === 🔔 SLACK ALERTING ===
# Incoming Webhook URL for drift / data-quality alerts (Grafana → Slack).
# Create at api.slack.com/apps → Incoming Webhooks. Leave blank here; set the
# real value only in your gitignored .env (never commit it).
SLACK_WEBHOOK_URL=

# === ☁️ GCP / CLOUD (used by the Terraform infra; safe placeholders here) ===
# GCP project that hosts the self-hosted redis-stack VM + remote Terraform state.
GCP_PROJECT_ID=
GCP_REGION=us-central1

# === ☁️ CLOUD REDIS (self-hosted redis-stack on the GCP VM) ===
# Point the pipeline at the cloud Redis: set REDIS_HOST to the VM IP, REDIS_PASSWORD
# to the Secret Manager value, and REDIS_TLS=true if the VM terminates TLS.
REDIS_TLS=false