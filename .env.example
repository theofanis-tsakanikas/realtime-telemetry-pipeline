# ==============================================================================
# 📡 IoT Data Pipeline - Environment Configuration Example
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to create a local .env file: cp .env.example .env
# 2. Modify the values below according to your setup.
# 3. DO NOT commit the actual .env file to version control (Git).
# ==============================================================================

# === 📨 KAFKA SETTINGS ===
# Default is 'kafka:9092' for running scripts INSIDE Docker.
# Change to 'localhost:29092' ONLY if running scripts on your local host machine.
KAFKA_BROKER=kafka-broker:9092
KAFKA_TOPIC=sensor_data

# === 🌡️ SIMULATOR SETTINGS ===
SENSOR_COUNT=5
DELAY_SECONDS=1.0
MAX_RETRIES=10
RETRY_DELAY=3

# === 🧠 REDIS SETTINGS ===
# Default is 'redis' for running scripts INSIDE Docker.
# Change to 'localhost' ONLY if running scripts on your local host machine.
REDIS_HOST=redis
REDIS_PORT=6379

# === ⚙️ SPARK STREAMING SETTINGS ===
# Checkpoint directory for Spark Fault Tolerance.
# Stored inside the /data volume which is ignored by Git.
CHECKPOINT_DIR=./data/checkpoints/sensor_data