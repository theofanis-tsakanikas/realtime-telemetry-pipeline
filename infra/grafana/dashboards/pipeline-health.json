{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
      "description": "Spark Structured Streaming throughput — records/sec read from Kafka (input) vs processed (process), summed across the streaming queries. From Prometheus, scraped off the Spark driver.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "rec/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
          "expr": "sum({__name__=~\".*inputRate_total_Value\"})",
          "legendFormat": "Input rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
          "expr": "sum({__name__=~\".*processingRate_total_Value\"})",
          "legendFormat": "Processing rate",
          "refId": "B"
        }
      ],
      "title": "Streaming Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
      "description": "Average end-to-end micro-batch latency across the streaming queries (ms).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
          "expr": "avg({__name__=~\".*latency_Value\"})",
          "legendFormat": "Batch latency",
          "refId": "A"
        }
      ],
      "title": "Micro-batch Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
      "description": "Spark JVM heap memory usage (driver/executor). Sawtooth is normal — memory fills, then GC reclaims it.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
          "expr": "{__name__=~\".*_ExecutorMetrics_JVMHeapMemory_Value\"}",
          "legendFormat": "JVM heap",
          "refId": "A"
        }
      ],
      "title": "JVM Heap Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
      "description": "JVM garbage-collection counts (cumulative). Steady minor GC = healthy memory churn.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "count",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
          "expr": "{__name__=~\".*_ExecutorMetrics_MinorGCCount_Value\"}",
          "legendFormat": "Minor GC",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-iot" },
          "expr": "{__name__=~\".*_ExecutorMetrics_MajorGCCount_Value\"}",
          "legendFormat": "Major GC",
          "refId": "B"
        }
      ],
      "title": "Garbage Collection",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["spark", "pipeline", "system"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Pipeline Health (Spark)",
  "uid": "pipeline-health",
  "version": 1
}
